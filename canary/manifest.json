{
  "manifest_version": 2,
  "name": "Zotero Compatibility Canary",
  "version": "0.0.2",
  "description": "Minimal Zotero plugin used only to test local XPI installation compatibility.",
  "applications": {
    "zotero": {
      "id": "zotero-compatibility-canary@example.com",
      "strict_min_version": "7.0",
      "strict_max_version": "9.0.*",
      "update_url": "https://example.com/zotero-compatibility-canary/updates.json"
    }
  }
}
