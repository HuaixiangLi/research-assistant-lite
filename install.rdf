<?xml version="1.0"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">
  <Description about="urn:mozilla:install-manifest">
    <em:id>research-assistant-lite@example.com</em:id>
    <em:name>Research Assistant Lite</em:name>
    <em:version>0.3.6</em:version>
    <em:description>Local explainable paper tagging, rule-based search, research overview, and duplicate hints for Zotero.</em:description>
    <em:creator>Codex</em:creator>
    <em:type>2</em:type>
    <em:bootstrap>true</em:bootstrap>
    <em:unpack>true</em:unpack>
    <em:targetApplication>
      <Description>
        <em:id>zotero@chnm.gmu.edu</em:id>
        <em:minVersion>7.0</em:minVersion>
        <em:maxVersion>9.0.*</em:maxVersion>
      </Description>
    </em:targetApplication>
  </Description>
</RDF>
