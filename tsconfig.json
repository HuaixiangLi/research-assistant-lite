{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "bootstrap.js",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/types/**/*.d.ts",
    "scripts/**/*.mjs",
    "test/**/*.mjs"
  ]
}
